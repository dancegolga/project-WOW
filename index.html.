<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Проект Исток: Резонанс Хромосомы</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;500;700&display=swap');
        body { font-family: 'Fira Code', monospace; background-color: #020617; overflow-x: hidden; }
        .dna-node { transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1); }
        .glow-sky { box-shadow: 0 0 20px rgba(56, 189, 248, 0.6); }
        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
        .fade-in { animation: fadeIn 1.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="text-slate-200 p-4">
    <div id="root" class="max-w-5xl mx-auto py-8 fade-in">
        <header class="mb-12 border-b border-sky-900 pb-6 text-center">
            <h1 class="text-4xl font-bold text-sky-400 tracking-tighter mb-2">ПРОЕКТ ИСТОК</h1>
            <p class="text-slate-500 text-sm uppercase tracking-[0.3em]">Синхронизация: Wow! Signal & Chromosome 13</p>
        </header>

        <div class="bg-slate-900 rounded-[2.5rem] p-8 border border-slate-800 shadow-2xl mb-10 relative overflow-hidden">
            <div id="coherence-line" class="absolute top-0 left-0 h-1 bg-sky-500 transition-all duration-1000 w-full shadow-[0_0_15px_#0ea5e9]"></div>
            
            <!-- Поля ввода ключа -->
            <div class="flex flex-wrap justify-center gap-6 mb-16" id="input-container">
                <!-- Генерируется JS -->
            </div>

            <!-- Визуализация ДНК -->
            <div class="relative h-96 bg-black/40 rounded-3xl p-10 flex items-center justify-center border border-slate-800/50 shadow-inner">
                <div id="dna-container" class="flex items-center w-full justify-between gap-1 overflow-hidden h-full px-4">
                    <!-- Нуклеотиды генерируются JS -->
                </div>
                
                <div id="error-overlay" class="absolute inset-0 flex items-center justify-center bg-slate-950/80 backdrop-blur-md transition-all duration-500 opacity-0 pointer-events-none rounded-3xl">
                    <div class="text-center p-8 border border-red-900/30 rounded-3xl bg-slate-900/50">
                        <div class="text-red-500 text-6xl mb-4">⚠️</div>
                        <p class="text-red-400 font-black tracking-widest text-2xl uppercase">Декогеренция</p>
                        <p class="text-xs text-slate-500 mt-2 italic">Математический ключ не совпадает с биологическим паттерном</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2 bg-slate-900/40 p-8 rounded-3xl border border-slate-800">
                <h3 class="text-sky-400 font-bold mb-4 flex items-center gap-3">
                    <span class="w-3 h-3 bg-sky-500 rounded-full animate-ping"></span>
                    ЛОГИКА ПРОТОКОЛА
                </h3>
                <p class="text-sm text-slate-400 leading-relaxed italic border-l-2 border-sky-800 pl-4">
                    "Когда значения сигнала 6EQUJ5 (6-14-26-30-19-5) вводятся в терминал, они создают интерференционную сетку. 
                    В этот момент хаотичные данные 13-й хромосомы резонируют с частотой Войда Волопаса, выстраивая ровную структуру. 
                    Это прямое доказательство того, что наш геном — это аппаратно-зависимый код."
                </p>
            </div>
            
            <div class="bg-slate-900/40 p-8 rounded-3xl border border-slate-800 flex flex-col items-center justify-center">
                <div id="coherence-percent" class="text-6xl font-black text-sky-400 drop-shadow-[0_0_15px_#0ea5e9]">100%</div>
                <div class="text-[10px] uppercase tracking-[0.2em] text-slate-500 mt-4 font-bold">Когерентность цепи</div>
                <div class="w-full bg-slate-800 h-2 mt-8 rounded-full overflow-hidden">
                    <div id="coherence-bar" class="h-full bg-sky-500 transition-all duration-1000 w-full shadow-[0_0_10px_#0ea5e9]"></div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const correct = [6, 14, 26, 30, 19, 5];
        const labels = ['6', 'E (14)', 'Q (26)', 'U (30)', 'J (19)', '5'];
        let currentValues = [6, 14, 26, 30, 19, 5];
        const dnaLetters = "ATGC".repeat(25).split("");

        const inputContainer = document.getElementById('input-container');
        const dnaContainer = document.getElementById('dna-container');
        const errorOverlay = document.getElementById('error-overlay');
        const coherencePercent = document.getElementById('coherence-percent');
        const coherenceBar = document.getElementById('coherence-bar');
        const coherenceLine = document.getElementById('coherence-line');

        // Инициализация инпутов
        labels.forEach((label, i) => {
            const wrapper = document.createElement('div');
            wrapper.className = 'flex flex-col items-center';
            wrapper.innerHTML = `
                <span class="text-[10px] text-slate-500 mb-2 font-bold uppercase">${label}</span>
                <input type="number" value="${currentValues[i]}" 
                    class="w-16 h-14 bg-slate-800 border-2 border-sky-500 text-sky-300 rounded-2xl text-center text-xl font-bold transition-all focus:outline-none glow-sky"
                    data-index="${i}">
            `;
            inputContainer.appendChild(wrapper);
        });

        // Инициализация ДНК
        dnaLetters.forEach((letter, i) => {
            const node = document.createElement('div');
            node.className = 'dna-node flex flex-col items-center shrink-0';
            node.innerHTML = `
                <div class="up-bar w-1 bg-sky-400 h-32 glow-sky opacity-100 rounded-full"></div>
                <span class="letter text-[10px] my-3 text-sky-300 font-bold scale-125">${letter}</span>
                <div class="down-bar w-1 bg-sky-400 h-32 glow-sky opacity-100 rounded-full"></div>
            `;
            dnaContainer.appendChild(node);
        });

        function update() {
            let matches = 0;
            currentValues.forEach((v, i) => { if (v === correct[i]) matches++; });
            const coherence = Math.round((matches / 6) * 100);

            // Обновление UI
            coherencePercent.textContent = `${coherence}%`;
            coherenceBar.style.width = `${coherence}%`;
            coherenceLine.style.width = `${coherence}%`;

            if (coherence === 100) {
                errorOverlay.style.opacity = '0';
                coherencePercent.className = 'text-6xl font-black text-sky-400 drop-shadow-[0_0_15px_#0ea5e9]';
                coherenceBar.className = 'h-full bg-sky-500 transition-all duration-1000';
            } else {
                errorOverlay.style.opacity = '1';
                coherencePercent.className = 'text-6xl font-black text-red-900';
                coherenceBar.className = 'h-full bg-red-900 transition-all duration-1000';
            }

            // Анимация узлов ДНК
            const nodes = document.querySelectorAll('.dna-node');
            let currentPos = 0;
            const activePoints = [];
            correct.forEach(step => {
                currentPos += step;
                activePoints.push(currentPos);
            });

            nodes.forEach((node, i) => {
                const upBar = node.querySelector('.up-bar');
                const downBar = node.querySelector('.down-bar');
                const letter = node.querySelector('.letter');
                const isActive = coherence === 100 && activePoints.includes(i);

                if (isActive) {
                    upBar.className = 'up-bar w-1 bg-sky-400 h-32 glow-sky opacity-100 rounded-full';
                    downBar.className = 'down-bar w-1 bg-sky-400 h-32 glow-sky opacity-100 rounded-full';
                    letter.className = 'letter text-[10px] my-3 text-sky-300 font-bold scale-150';
                    node.style.transform = 'translateY(0)';
                } else {
                    const h = coherence === 100 ? '4px' : '20px';
                    upBar.className = `up-bar w-1 bg-slate-800 h-[${h}] opacity-20 rounded-full`;
                    downBar.className = `down-bar w-1 bg-slate-800 h-[${h}] opacity-20 rounded-full`;
                    letter.className = 'letter text-[10px] my-3 text-slate-700';
                    if (coherence < 100) {
                        node.style.transform = `translateY(${Math.random() * 20 - 10}px)`;
                    } else {
                        node.style.transform = 'translateY(0)';
                    }
                }
            });
        }

        document.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', (e) => {
                const idx = e.target.dataset.index;
                const val = parseInt(e.target.value);
                currentValues[idx] = isNaN(val) ? 0 : val;
                
                if (currentValues[idx] === correct[idx]) {
                    e.target.className = 'w-16 h-14 bg-slate-800 border-2 border-sky-500 text-sky-300 rounded-2xl text-center text-xl font-bold transition-all focus:outline-none glow-sky';
                } else {
                    e.target.className = 'w-16 h-14 bg-slate-800 border-2 border-red-900/50 text-red-400 rounded-2xl text-center text-xl font-bold transition-all focus:outline-none';
                }
                update();
            });
        });

        // Первый запуск
        update();
    </script>
</body>
</html>
